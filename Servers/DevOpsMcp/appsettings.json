{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Observability": {
    "File": {
      "Enabled": true,
      "Path": "devops-mcp.log",
      "MinimumLevel": "Information"
    },
    "AppInsights": {
      "Enabled": false,
      "ConnectionString": ""
    }
  },
  "AllowedHosts": "*",
  "PORT": "8002",
  "MCP_HTTP_HOST": "localhost",
  "TFS_BASE_URL":"<tfs url>",
  "TFS_PAT":"<PAT Token>",
  "TFS_TIMEOUT_SECONDS": 135
}
