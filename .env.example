# Copy this file to .env before running docker compose.

# McpHost
LLM_PROVIDER=openai
LLM_MODEL=
OPENAI_MODEL=gpt-4.1-mini
GEMINI_MODEL=gemini-2.5-flash
API_PORT=8888
LLM_REASONING_EFFORT=medium
OPENAI_REASONING_EFFORT=
OPENAI_API_KEY=
GEMINI_API_KEY=
SESSION_TTL_SECS=3600
SYSTEM_INSTRUCTION=
CORS_ORIGINS=http://localhost:4200

# Optional host MCP endpoint overrides. docker-compose already supplies local defaults.
UW_SERVER_URL=
DEVOPS_SERVER_URL=

# UwMcp
SUBMISSION_URL=
QUOTE_URL=
APIM_BASE_URL=
APIM_SUBSCRIPTION_KEY=Ocp-Apim-Subscription-Key
APIM_SUBSCRIPTION_KEY_VALUE=

# DevOpsMcp
TFS_BASE_URL=
TFS_PAT=
