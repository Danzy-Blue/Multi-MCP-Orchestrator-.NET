{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Observability": {
    "File": {
      "Enabled": true,
      "Path": "mcp-host.log",
      "MinimumLevel": "Information"
    },
    "AppInsights": {
      "Enabled": false,
      "ConnectionString": ""
    }
  },
  "AllowedHosts": "*",
  "AppConfig": {
    "LlmProvider": "gemini",
    "LlmModel": "gemini-2.5-flash",
    "LlmReasoningEffort": null,
    "GeminiApiKey": "",
    "OpenAiApiKey": "",
    "ApiPort": 8888,
    "SessionTtlSeconds": 3600,
    "CorsOrigins": [
      "*"
    ],
    "ServerConfigs": [
      {
        "Alias": "uw",
        "Url": "http://localhost:8001/mcp"
      },
      {
        "Alias": "devops",
        "Url": "http://localhost:8002/mcp"
      }
    ],
    "AppTitle": "MCP Chat API",
    "SystemInstruction": null
  }
}
